# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_USER_ID=        # seu ID pessoal para receber DMs do bot

# IA — escolha o provedor e preencha somente a key correspondente
AI_PROVIDER=gemini      # opções: gemini | anthropic | openai

GEMINI_API_KEY=         # gratuito em: https://aistudio.google.com/apikey
GEMINI_MODEL=           # opcional (padrão: gemini-2.0-flash)

ANTHROPIC_API_KEY=      # pago em: https://console.anthropic.com
ANTHROPIC_MODEL=        # opcional (padrão: claude-sonnet-4-6)

OPENAI_API_KEY=         # pago em: https://platform.openai.com
OPENAI_MODEL=           # opcional (padrão: gpt-4o-mini)

# GitHub
GITHUB_TOKEN=           # https://github.com/settings/tokens

# Banco
DATABASE_URL="file:./den-den.db"
